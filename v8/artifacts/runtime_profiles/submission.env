# Default submission profile.
# Myeongseok-like LLM trigger policy with RAG context.
USE_LLM_PARSE_FALLBACK=1
ENABLE_RAG_REPAIR=0
ENABLE_PARSE_AUDIT=1

MODEL_NAME=Qwen/Qwen3.5-9B
HF_HOME=/workspace/cache/hf_cache
HF_HUB_OFFLINE=1

LLM_PARSE_MIN_CONFIDENCE=0.72
LLM_PARSE_MAX_NEW_TOKENS=384
LLM_PARSE_MAX_MODEL_LEN=4096
LLM_PARSE_LOCAL_FILES_ONLY=1
LLM_PARSE_STRUCTURED_OUTPUTS=1

LLM_PARSE_JUDGE_BELOW_CONFIDENCE=0.60
LLM_PARSE_JUDGE_PARTIAL=1
LLM_PARSE_JUDGE_WITH_FAILURE_CONTEXT=0
LLM_PARSE_TRUST_IMPLEMENTED_HIGH_CONF=1
LLM_PARSE_TRUST_MIN_CONFIDENCE=0.95

LLM_PARSE_REPAIR_NO_FAMILY=1
LLM_PARSE_REPAIR_NON_RW_COMMANDS=1
LLM_PARSE_REPAIR_NO_FAMILY_PRETARGET=0
LLM_PARSE_REPAIR_NON_RW_COMMANDS_PRETARGET=0
LLM_PARSE_REPAIR_INFERRED=0
LLM_PARSE_REPAIR_FAILED_EVENTS=0

LLM_PARSE_ENABLE_RAG=1
LLM_PARSE_RAG_TOP_K=8
LLM_PARSE_RAG_MAX_CHARS=3500
RAG_MAX_CHUNK_CHARS=3500
